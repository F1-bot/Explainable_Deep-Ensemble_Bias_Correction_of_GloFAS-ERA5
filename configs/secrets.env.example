# ---------------------------------------------------------------------------
# Copernicus credentials template.
#
#   1. Copy this file to  configs/secrets.env
#   2. Replace each placeholder with YOUR OWN Personal Access Token.
#   3. configs/secrets.env is git-ignored and must NEVER be committed.
#
# Where to obtain the tokens (free registration):
#   CDS_KEY   -> Climate Data Store ......... https://cds.climate.copernicus.eu/
#   EWDS_KEY  -> Early Warning Data Store .... https://ewds.climate.copernicus.eu/
#               (GloFAS-ERA5 historical river discharge is served via EWDS)
#
# The two tokens are usually identical (one Copernicus account), but keep both
# keys so the CDS and EWDS API clients each find a value.
# ---------------------------------------------------------------------------
CDS_KEY=<your-personal-access-token>
EWDS_KEY=<your-personal-access-token>
